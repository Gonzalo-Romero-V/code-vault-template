{
  "_doc": "Stack archetype: Frontend Next.js standalone (sin backend en el monorepo).",
  "_doc_extractor": "Usa el extractor 'nextjs-laravel' reusándolo solo para la parte Frontend; el resto queda ignorado por exclude_patterns.",
  "schema_version": "1.0",
  "project_name": "__PROJECT_NAME__",
  "vault_path": "__VAULT_ABSOLUTE_PATH__",
  "extractor": "nextjs-laravel",

  "hierarchy_mapping": {
    "H1_intent": ["vault/intent/**"],
    "H2_requirements": ["vault/domain/**", "vault/raw/**"],
    "H3_architecture": [
      "vault/decisions/**",
      "components.json",
      "tsconfig.json",
      "next.config.*",
      "postcss.config.*",
      "eslint.config.*",
      "app/globals.css",
      "package.json",
      ".gitignore",
      ".gitattributes"
    ],
    "H4_contracts": [
      "components/ui/**",
      "components/layout/**",
      "components/custom/**",
      "app/api/**",
      "lib/**",
      "hooks/**",
      "types/**",
      "app/**/layout.tsx"
    ],
    "H5_implementation": [
      "app/**/page.tsx",
      "app/**/loading.tsx",
      "app/**/error.tsx",
      "components/**"
    ],
    "ENV_references": [".env", ".env.example", ".env.local", ".env.production"]
  },

  "exclude_patterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/*.lock",
    "**/*-lock.json",
    "**/*.log",
    "**/graphify-out/**"
  ],

  "env_scan_scope": ["app/**", "components/**", "lib/**", "src/**", "hooks/**"],

  "vault_protected_status": ["locked"],

  "report_size_limits": {
    "max_files": 100,
    "max_diff_chars_per_file": 500,
    "split_threshold_files": 30
  }
}
